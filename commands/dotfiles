#!/usr/bin/env zsh

# 1. Definimos las opciones como un array simple
local -a sub_params
sub_params=(init)

local REAL_USER="pato"
local USER_ID=$(id -u $REAL_USER)

# Buscamos '--list' en todos los argumentos recibidos ($*)
if [[ " $* " == *" --list "* ]]; then
    echo "${(j: :)sub_params}"
    return 0
fi

# 3. Lógica del comando
case "$1" in
    init)
        #!/bin/zsh

        # 1. Preguntar por la ruta de destino (Obligatoria)
        # Se usa un bucle hasta que la entrada no esté vacía
        while [[ -z "$DEST_PATH" ]]; do
            print -n "Introduce la ruta donde guardar los datos (obligatorio): "
            read DEST_PATH
        done

        # 2. Preguntar por la ruta de origen (Con valor por defecto)
        print -n "Introduce la ruta de donde leer los datos [Por defecto: $HOME]: "
        read SOURCE_PATH
        # Si la respuesta está vacía, asignar $HOME
        : ${SOURCE_PATH:=$HOME}

        # 3. Preguntar por el remoto de git (Opcional)
        print -n "Introduce el remoto de Git (opcional, presiona Enter para omitir): "
        read GIT_REMOTE

        # --- Verificación de resultados ---
        echo "\n--- Configuración guardada ---"
        echo "Destino: $DEST_PATH"
        echo "Origen:  $SOURCE_PATH"
        echo "Git:     ${GIT_REMOTE:-"No configurado"}"

        ;;
    *)
        echo "Uso: alfred update {${(j:|:)sub_params}}"
        return 1
        ;;
esac
